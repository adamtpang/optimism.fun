# optimism.fun env vars
#
# Email capture + feedback both route through Resend (https://resend.com).
# Free tier: 3,000 emails/month + 1 audience list — enough for now.
#
# Admin panels:
#   Email signups → https://resend.com/audiences
#   Feedback      → whatever address you set RESEND_NOTIFY_EMAIL to (defaults
#                   to adamtpang@gmail.com). Each submission lands as a real
#                   email, so your inbox = your admin panel.
#
# Set these in Vercel: Settings → Environment Variables.

# Resend API key (server-side only; do NOT prefix NEXT_PUBLIC_)
RESEND_API_KEY=

# Audience ID from https://resend.com/audiences (one-per-product is fine)
RESEND_AUDIENCE_ID=

# Where feedback submissions get emailed. Optional — defaults to
# adamtpang@gmail.com if unset.
RESEND_NOTIFY_EMAIL=adamtpang@gmail.com

# Verified sender address. Must be verified in Resend Domains.
# If you haven't verified a domain yet, keep the Resend sandbox address.
RESEND_FROM_EMAIL=optimism.fun <onboarding@resend.dev>
