# optimism.fun local env vars
#
# Admin panel for both forms = your Formspree dashboard at https://formspree.io/forms
# Create two separate forms (one for feedback, one for email signups) so you
# can tell them apart. Copy the form ID (e.g. "xvojabcd" or "mrbgpqnl").
#
# In Vercel: Settings → Environment Variables → paste both below with the
# same names, prefixed NEXT_PUBLIC_ so they're available client-side.

NEXT_PUBLIC_FORMSPREE_FEEDBACK_ID=
NEXT_PUBLIC_FORMSPREE_EMAIL_ID=
